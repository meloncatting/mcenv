{
  "name": "mcenv",
  "version": "1.0.0",
  "description": "Docker-like reproducible environment system for Minecraft servers",
  "bin": {
    "mcenv": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=bundle.cjs",
    "package": "npm run bundle && npx pkg bundle.cjs --targets node18-linux-x64,node18-macos-x64,node18-win-x64 --output mcenv",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.8",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  }
}
